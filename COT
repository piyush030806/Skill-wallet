<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Principal Engineer | [Your Name] | Software Architecture</title>
    <meta name="description" content="Portfolio of a Senior Software Architect specializing in distributed systems and technical leadership.">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Lexend:wght@300;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            /* Palette */
            --bg-deep: #0B0F19;
            --bg-surface: #111827;
            --accent: #7C3AED;
            --grad-1: #22D3EE;
            --grad-2: #A78BFA;
            --text-main: #F9FAFB;
            --text-muted: #9CA3AF;
            --glass-border: rgba(255, 255, 255, 0.1);
            --glass-bg: rgba(17, 24, 39, 0.7);
            
            /* Spacing */
            --section-gap: 8rem;
            --container-max: 1200px;
        }

        [data-theme="light"] {
            --bg-deep: #F3F4F6;
            --bg-surface: #FFFFFF;
            --text-main: #111827;
            --text-muted: #4B5563;
            --glass-bg: rgba(255, 255, 255, 0.8);
            --glass-border: rgba(0, 0, 0, 0.1);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            cursor: none; /* Custom cursor */
        }

        html {
            scroll-behavior: smooth;
            font-size: 16px;
        }

        body {
            font-family: 'Inter', sans-serif;
            background-color: var(--bg-deep);
            color: var(--text-main);
            line-height: 1.6;
            overflow-x: hidden;
        }

        h1, h2, h3, .nav-logo {
            font-family: 'Lexend', sans-serif;
        }

        /* --- Canvas Background & Cursor --- */
        #hero-canvas {
            position: fixed;
            top: 0;
            left: 0;
            z-index: -1;
            pointer-events: none;
        }

        #custom-cursor {
            width: 20px;
            height: 20px;
            background: var(--grad-1);
            border-radius: 50%;
            position: fixed;
            pointer-events: none;
            z-index: 9999;
            mix-blend-mode: difference;
            transition: transform 0.1s ease;
        }

        /* --- Glassmorphism Components --- */
        .glass {
            background: var(--glass-bg);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid var(--glass-border);
            border-radius: 16px;
        }

        /* --- Layout --- */
        .container {
            max-width: var(--container-max);
            margin: 0 auto;
            padding: 0 2rem;
        }

        /* --- Navigation --- */
        nav {
            position: fixed;
            top: 0;
            width: 100%;
            height: 70px;
            z-index: 100;
            display: flex;
            align-items: center;
            transition: all 0.3s ease;
        }

        nav.scrolled {
            background: var(--glass-bg);
            backdrop-filter: blur(15px);
            border-bottom: 1px solid var(--glass-border);
        }

        .nav-content {
            width: 100%;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .nav-links {
            display: flex;
            gap: 2rem;
            list-style: none;
        }

        .nav-links a {
            text-decoration: none;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.9rem;
            transition: color 0.3s;
        }

        .nav-links a:hover {
            color: var(--grad-1);
        }

        .theme-toggle {
            background: none;
            border: 1px solid var(--glass-border);
            color: var(--text-main);
            padding: 0.5rem;
            border-radius: 8px;
            cursor: pointer;
        }

        /* --- Hero Section --- */
        .hero {
            height: 100vh;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }

        .hero-badge {
            display: inline-block;
            padding: 0.5rem 1rem;
            background: linear-gradient(90deg, var(--grad-1), var(--grad-2));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 800;
            font-size: 0.9rem;
            letter-spacing: 2px;
            text-transform: uppercase;
            margin-bottom: 1rem;
        }

        .hero h1 {
            font-size: clamp(3rem, 8vw, 5.5rem);
            line-height: 1.1;
            margin-bottom: 1.5rem;
            font-weight: 800;
        }

        .role-switcher {
            font-size: 1.5rem;
            color: var(--text-muted);
            min-height: 1.6em;
        }

        .cta-group {
            margin-top: 3rem;
            display: flex;
            gap: 1.5rem;
        }

        .btn {
            padding: 1rem 2rem;
            border-radius: 12px;
            text-decoration: none;
            font-weight: 600;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .btn-primary {
            background: var(--accent);
            color: white;
            box-shadow: 0 10px 20px -10px var(--accent);
        }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 30px -10px var(--accent);
        }

        .btn-outline {
            border: 1px solid var(--glass-border);
            color: var(--text-main);
        }

        /* --- Section Styling --- */
        section {
            padding: var(--section-gap) 0;
        }

        .section-title {
            margin-bottom: 4rem;
        }

        .section-title h2 {
            font-size: 2.5rem;
            margin-bottom: 1rem;
        }

        .section-title p {
            color: var(--text-muted);
            max-width: 600px;
        }

        /* --- Leadership Grid --- */
        .leadership-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
        }

        .lead-card {
            padding: 2.5rem;
            transition: transform 0.3s;
        }

        .lead-card:hover {
            transform: translateY(-10px);
        }

        .lead-icon {
            font-size: 2rem;
            margin-bottom: 1.5rem;
            display: block;
        }

        /* --- Case Studies (3D Cards) --- */
        .case-grid {
            perspective: 1000px;
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(400px, 1fr));
            gap: 3rem;
        }

        .case-card {
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.23, 1, 0.32, 1);
            padding: 3rem;
        }

        .case-card:hover {
            transform: rotateY(5deg) rotateX(2deg);
        }

        .impact-metric {
            display: flex;
            gap: 2rem;
            margin: 2rem 0;
        }

        .metric {
            font-family: 'Lexend';
        }

        .metric .val {
            display: block;
            font-size: 1.5rem;
            font-weight: 800;
            color: var(--grad-1);
        }

        .metric .label {
            font-size: 0.75rem;
            text-transform: uppercase;
            color: var(--text-muted);
        }

        /* --- Skills Matrix --- */
        .skills-matrix {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 4rem;
        }

        .skill-group h3 {
            margin-bottom: 1.5rem;
            color: var(--grad-2);
        }

        .skill-bar-container {
            margin-bottom: 1.5rem;
        }

        .skill-info {
            display: flex;
            justify-content: space-between;
            margin-bottom: 0.5rem;
        }

        .skill-bar {
            height: 6px;
            background: var(--bg-surface);
            border-radius: 3px;
            overflow: hidden;
        }

        .skill-progress {
            height: 100%;
            background: linear-gradient(90deg, var(--grad-1), var(--grad-2));
            width: 0;
            transition: width 1.5s ease-out;
        }

        /* --- Timeline --- */
        .timeline {
            position: relative;
            padding-left: 2rem;
            border-left: 2px solid var(--glass-border);
        }

        .timeline-item {
            margin-bottom: 4rem;
            position: relative;
        }

        .timeline-item::before {
            content: '';
            position: absolute;
            left: -2.7rem;
            top: 0;
            width: 20px;
            height: 20px;
            background: var(--bg-deep);
            border: 4px solid var(--accent);
            border-radius: 50%;
        }

        /* --- Footer --- */
        footer {
            padding: 4rem 0;
            border-top: 1px solid var(--glass-border);
            text-align: center;
        }

        /* --- Reveal Animation --- */
        .reveal {
            opacity: 0;
            transform: translateY(30px);
            transition: all 0.8s ease-out;
        }

        .reveal.active {
            opacity: 1;
            transform: translateY(0);
        }

        /* --- Responsive --- */
        @media (max-width: 768px) {
            cursor: auto !important;
            #custom-cursor { display: none; }
            * { cursor: auto !important; }
            .hero h1 { font-size: 3rem; }
            .skills-matrix { grid-template-columns: 1fr; }
            .case-grid { grid-template-columns: 1fr; }
            .nav-links { display: none; }
        }
    </style>
</head>
<body>

