    <!-- Modern Typography: Inter for UI, Source Code Pro for Technical bits -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Source+Code+Pro:wght@400;600&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #ffffff;
            --text-main: #1a1a1a;
            --text-muted: #555555;
            --accent: #2563eb;
            --border: #eeeeee;
            --code-bg: #f6f8fa;
            --max-width: 850px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', -apple-system, sans-serif;
            line-height: 1.6;
            color: var(--text-main);
            background-color: var(--bg);
            padding: 2rem 1rem;
        }

        .container {
            max-width: var(--max-width);
            margin: 0 auto;
        }

        /* --- Header & Intro --- */
        header {
            margin-bottom: 4rem;
        }

        h1 {
            font-size: 2.2rem;
            font-weight: 700;
            letter-spacing: -0.02em;
            margin-bottom: 0.5rem;
        }

        .subtitle {
            font-size: 1.1rem;
            color: var(--text-muted);
            margin-bottom: 1.5rem;
        }

        .links {
            display: flex;
            gap: 1.2rem;
            font-size: 0.9rem;
            font-weight: 500;
        }

        .links a {
            color: var(--accent);
            text-decoration: none;
            border-bottom: 1px solid transparent;
        }

        .links a:hover {
            border-bottom: 1px solid var(--accent);
        }

        /* --- Global Section Styles --- */
        section {
            margin-bottom: 4rem;
        }

        h2 {
            font-size: 1.3rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            margin-bottom: 1.5rem;
            border-bottom: 2px solid var(--text-main);
            display: inline-block;
        }

        /* --- About --- */
        .about-text {
            font-size: 1.05rem;
            max-width: 750px;
        }

        /* --- Skills Table --- */
        .skills-grid {
            display: grid;
            grid-template-columns: 1fr 2fr;
            gap: 1rem;
            font-size: 0.95rem;
        }

        .skill-cat {
            font-weight: 600;
            color: var(--text-main);
        }

        .skill-vals {
            color: var(--text-muted);
            font-family: 'Source Code Pro', monospace;
            font-size: 0.85rem;
        }

        /* --- Experience Timeline --- */
        .timeline-item {
            margin-bottom: 2.5rem;
            position: relative;
        }

        .exp-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 0.5rem;
        }

        .exp-title {
            font-weight: 700;
            font-size: 1.1rem;
        }

        .exp-date {
            font-family: 'Source Code Pro', monospace;
            font-size: 0.85rem;
            color: var(--text-muted);
        }

        .exp-company {
            color: var(--accent);
            font-weight: 500;
            margin-bottom: 0.5rem;
        }

        .exp-list {
            list-style: none;
            margin-left: 0.5rem;
        }

        .exp-list li {
            margin-bottom: 0.4rem;
            position: relative;
            padding-left: 1.2rem;
        }

        .exp-list li::before {
            content: "→";
            position: absolute;
            left: 0;
            color: var(--text-muted);
        }

        /* --- Project Case Studies --- */
        .project-card {
            margin-bottom: 3rem;
            padding: 1.5rem;
            background: var(--code-bg);
            border-radius: 4px;
        }

        .project-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }

        .project-title {
            font-size: 1.2rem;
            font-weight: 700;
        }

        .project-meta {
            font-size: 0.8rem;
            font-family: 'Source Code Pro', monospace;
            background: #e2e8f0;
            padding: 2px 8px;
            border-radius: 3px;
        }

        .case-study {
            display: grid;
            grid-template-columns: 100px 1fr;
            gap: 0.5rem;
            font-size: 0.95rem;
            margin-top: 1rem;
        }

        .label {
            font-weight: 600;
            font-size: 0.8rem;
            text-transform: uppercase;
            color: var(--text-muted);
            padding-top: 0.2rem;
        }

        .result-highlight {
            color: #059669; /* Success Green */
            font-weight: 600;
        }

        /* --- Publications & Blogs --- */
        .pub-item {
            margin-bottom: 1rem;
            font-size: 0.95rem;
        }

        .pub-title {
            font-weight: 500;
            text-decoration: none;
            color: var(--text-main);
        }

        .pub-title:hover {
            color: var(--accent);
        }

        /* --- Contact --- */
        .contact-footer {
            border-top: 1px solid var(--border);
            padding-top: 2rem;
            text-align: center;
            color: var(--text-muted);
            font-size: 0.9rem;
        }

        /* --- Responsive --- */
        @media (max-width: 600px) {
            .exp-header { flex-direction: column; }
            .skills-grid { grid-template-columns: 1fr; }
            .case-study { grid-template-columns: 1fr; }
            h1 { font-size: 1.8rem; }
        }
    </style>
</head>
