        <div class="projects-grid">
            <!-- Project 1 -->
            <div class="project-card">
                <div class="project-content">
                    <h3>Semantic Search Engine</h3>
                    <p>Built a document retrieval system using BERT embeddings and Faiss for high-speed similarity search across 100k+ technical articles.</p>
